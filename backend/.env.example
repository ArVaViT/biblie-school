# Backend environment variables
# ------------------------------------------------------------------------------
# Copy this file to .env (which is gitignored) and fill in real values.
# ALL variables below are read by app/core/config.py. See that file for the
# fallback / aliasing logic.
#
# NEVER commit a real .env. Never paste secrets into chat, logs, or issues.
# ------------------------------------------------------------------------------

# ──── Supabase ────────────────────────────────────────────────────────────────
# Project URL from Supabase → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co

# Server-only key used for admin queries (e.g. reading auth.users to sync
# profile rows). This is the `service_role` key (Project Settings → API →
# service_role). It MUST NEVER reach the browser — there is no public-facing
# code path that needs it.
#
# The legacy SUPABASE_KEY env var name is still accepted for backwards
# compatibility but logs a deprecation warning at startup. Prefer the explicit
# name below so the key's scope is obvious at a glance.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──── Database ────────────────────────────────────────────────────────────────
# Pooled connection string from Supabase (Settings → Database → Connection
# Pooler, "Session" mode for Alembic, "Transaction" mode for serverless).
#
# POSTGRES_URL and POSTGRES_PRISMA_URL are also accepted as aliases — handy
# when the project is attached to Vercel's Postgres/Neon marketplace
# integration, which auto-provisions those names.
DATABASE_URL=postgresql://user:password@host:port/database
# POSTGRES_URL=postgresql://user:password@host:port/database
# POSTGRES_PRISMA_URL=postgresql://user:password@host:port/database?pgbouncer=true

# ──── JWT ─────────────────────────────────────────────────────────────────────
# Used to verify Supabase access tokens server-side. Get it from Supabase →
# Project Settings → API → JWT Secret. Must be HS256.
JWT_SECRET_KEY=your-supabase-jwt-secret
JWT_ALGORITHM=HS256

# Alternative env var name — if SUPABASE_JWT_SECRET is set, it wins over
# JWT_SECRET_KEY. Set one or the other; do not duplicate.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ──── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins. Include every deployed frontend domain plus local
# dev ports. Preview-deployment URLs from Vercel should be added here too.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://biblie-school-frontend.vercel.app

# ──── Optional ────────────────────────────────────────────────────────────────
# Sentry DSN (server-side error monitoring). Leave unset to disable.
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
